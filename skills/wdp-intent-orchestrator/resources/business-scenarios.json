      "api_flow": [
        {
          "step": 1,
          "description": "创建火点和危险范围对象",
          "api": "App.Scene.Creates",
          "params": {
            "entities": [
              {
                "type": "Poi",
                "location": "[116.4074, 39.9042, 50]",
                "poiStyle": {
                  "markerNormalUrl": "fire_icon.png",
                  "text": "火点"
                },
                "customId": "fire_point_1"
              },
              {
                "type": "Range",
                "polygon": {
                  "coordinates": "[[116.407, 39.904], [116.408, 39.904], ...]"
                },
                "rangeStyle": {
                  "fillColor": "rgba(255, 0, 0, 0.2)",
                  "outlineColor": "#ff0000",
                  "height": 100
                },
                "customId": "danger_zone_1"
              }
            ]
          }
        },
        {
          "step": 2,
          "description": "创建扑火队伍粒子实体",
          "api": "App.Scene.Creates",
          "params": {
            "entities": [
              {
                "type": "Particle",
                "location": "[116.400, 39.900, 0]",
                "particleType": "vehicle_fire_truck",
                "particleStyle": {
                  "scale": 1.2
                },
                "customId": "fire_team_1"
              }
            ]
          }
        },
        {
          "step": 3,
          "description": "创建灭火行动路径",
          "api": "App.Scene.Creates",
          "params": {
            "entities": [
              {
                "type": "Path",
                "polyline": {
                  "coordinates": "[[116.400, 39.900, 0], [116.4074, 39.9042, 0]]"
                },
                "pathStyle": {
                  "type": "arrow",
                  "lineColor": "#ff6600",
                  "lineWidth": 4
                },
                "customId": "action_path_1"
              }
            ]
          }
        },
        {
          "step": 4,
          "description": "绑定队伍到行动路径",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Bound()",
            "config": {
              "moving": "${fireTeamParticle}",
              "path": "${actionPath}",
              "boundStyle": {
                "time": 60,
                "bLoop": false,
                "speed": 1.5
              },
              "customId": "team_bound_1"
            }
          }
        },
        {
          "step": 5,
          "description": "聚焦到火点位置",
          "api": "App.CameraControl.FocusByLocation",
          "params": {
            "location": "[116.4074, 39.9042, 50]",
            "duration": 1000,
            "pitch": -60,
            "yaw": 0
          }
        },
        {
          "step": 6,
          "description": "创建指挥信息窗口",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Window()",
            "config": {
              "location": "[116.4074, 39.9042, 50]",
              "windowStyle": {
                "url": "command_dashboard.html?fireId=fire_1",
                "size": "[400, 500]",
                "offset": "[0, 2]"
              },
              "customId": "command_window_1"
            }
          }
        },
        {
          "step": 7,
          "description": "注册队伍到达事件",
          "api": "App.Renderer.RegisterSceneEvent",
          "params": {
            "events": [
              {
                "name": "OnBoundMoveEnd",
                "func": "async (ev) => { if(ev.result.customId.startsWith('team_bound')) { /* 队伍到达，更新状态 */ } }"
              }
            ]
          }
        },
        {
          "step": 8,
          "description": "更新火点状态标注",
          "api": "App.Scene.Update",
          "params": {
            "customId": "fire_point_1",
            "updateData": {
              "poiStyle": {
                "markerNormalUrl": "fire_controlled_icon.png",
                "text": "火点 (扑救中)"
              }
            }
          }
        }
      ],
      "data_flow": [
        {
          "step": "App.Scene.Creates",
          "output": "result.objects（含 eid, customId, location）",
          "usage": "缓存用于清理和后续更新"
