{
  "metadata": {
    "version": "2.1.0",
    "created_at": "2026-04-15",
    "description": "WDP 业务场景路由词典。用于场景识别、子任务拆解和 skill 路由提示。包含详细的 api_flow、data_flow 和 cleanup_chain。",
    "source": "基于 reference_skill/wdp-secondary-dev-skill/resources_architect/business-scenarios.json 迁移优化"
  },
  "scenarios": [
    {
      "id": "video-perimeter-monitoring",
      "name": "视频周界场景",
      "keywords": [
        "视频监控",
        "周界防护",
        "入侵检测",
        "实时告警",
        "视频分析",
        "AI识别"
      ],
      "synonyms": [
        "电子围栏",
        "围栏告警",
        "周界报警",
        "安防监控",
        "摄像头",
        "监控摄像",
        "视频点位",
        "安保监控",
        "视频联动",
        "围界"
      ],
      "priority": 10,
      "goal": "在三维场景中展示周界、监控点位、告警联动和视频窗口。",
      "task_breakdown": [
        "创建或加载周界范围对象",
        "创建监控点位或摄像头对象",
        "注册点击或告警联动事件",
        "触发视频窗口、聚焦或高亮",
        "补充离开页面后的清理链路"
      ],
      "primary_skills": [
        "wdp-api-coverings-unified",
        "wdp-api-general-event-registration"
      ],
      "secondary_skills": [
        "wdp-api-camera-unified",
        "wdp-api-function-components"
      ],
      "required_clarifications": [
        "摄像头对象类别和对象 Id 来源",
        "周界范围坐标或数据来源",
        "点击联动还是自动告警联动",
        "视频窗口的关闭和清理方式"
      ],
      "modules": [
        {
          "name": "场景实体模块",
          "wdp_apis": [
            "App.Scene.Add",
            "App.Scene.Update",
            "App.Scene.Delete",
            "App.Scene.Creates"
          ]
        },
        {
          "name": "POI标注模块",
          "wdp_apis": [
            "new App.Poi()",
            "poiStyle.markerNormalUrl",
            "poiStyle.markerSelectUrl",
            "poiStyle.text"
          ]
        },
        {
          "name": "周界围栏模块",
          "wdp_apis": [
            "new App.Range()",
            "rangeStyle.fillColor",
            "rangeStyle.outlineColor",
            "rangeStyle.height"
          ]
        },
        {
          "name": "视频窗口模块",
          "wdp_apis": [
            "new App.Window()",
            "windowStyle.url",
            "windowStyle.size",
            "windowStyle.offset"
          ]
        },
        {
          "name": "事件交互模块",
          "wdp_apis": [
            "App.Renderer.RegisterSceneEvent",
            "OnWdpSceneIsReady",
            "OnEntityClicked",
            "OnMouseEnterEntity"
          ]
        },
        {
          "name": "相机控制模块",
          "wdp_apis": [
            "App.CameraControl.FocusByCustomId",
            "App.CameraControl.FocusByLocation",
            "App.CameraControl.SetCameraPose"
          ]
        }
      ],
      "api_flow": [
        {
          "step": 1,
          "description": "批量创建AI摄像头POI标注",
          "api": "App.Scene.Creates",
          "params": {
            "entities": [
              {
                "type": "Poi",
                "location": "[121.464, 31.224, 47]",
                "poiStyle": {
                  "markerNormalUrl": "camera_icon.png",
                  "text": "AI摄像头1"
                },
                "customId": "camera_poi_1"
              }
            ],
            "options": {
              "calculateCoordZ": {
                "coordZRef": "surface",
                "coordZOffset": 2
              }
            }
          }
        },
        {
          "step": 2,
          "description": "创建周界围栏区域",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Range()",
            "config": {
              "polygon": {
                "coordinates": "[[121.464, 31.224], [121.465, 31.224], ...]"
              },
              "rangeStyle": {
                "fillColor": "rgba(255, 0, 0, 0.3)",
                "outlineColor": "#ff0000",
                "height": 50
              },
              "customId": "perimeter_zone_1"
            }
          }
        },
        {
          "step": 3,
          "description": "注册POI点击事件",
          "api": "App.Renderer.RegisterSceneEvent",
          "params": {
            "events": [
              {
                "name": "OnEntityClicked",
                "func": "async (ev) => { if(ev.result.customId.startsWith('camera_poi')) { /* 聚焦相机并显示视频窗口 */ } }"
              }
            ]
          }
        },
        {
          "step": 4,
          "description": "聚焦到选中的摄像头",
          "api": "App.CameraControl.FocusByCustomId",
          "params": {
            "customId": "${clickedPoiId}",
            "duration": 500,
            "pitch": -69,
            "yaw": 176
          }
        },
        {
          "step": 5,
          "description": "创建视频流窗口",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Window()",
            "config": {
              "location": "${cameraLocation}",
              "windowStyle": {
                "url": "video_stream.html?cameraId=${cameraId}",
                "size": "[250, 190]",
                "offset": "[0, 1.7]"
              },
              "customId": "video_window_${cameraId}"
            }
          }
        }
      ],
      "data_flow": [
        {
          "step": "App.Scene.Creates",
          "output": "result.objects（含 eid, customId, location）",
          "usage": "缓存用于清理；事件回调通过 customId 匹配业务数据"
        },
        {
          "step": "RegisterSceneEvent('OnEntityClicked') 回调",
          "output": "result.object.customId, result.object.location",
          "usage": "customId 用于 FocusByCustomId 和 Window 定位；location 用于 Window 位置"
        }
      ],
      "cleanup_chain": [
        {"create": "App.Scene.Creates(POI)", "cleanup": "App.Scene.Delete(customId)"},
        {"create": "App.Scene.Add(Range)", "cleanup": "rangeObj.Delete()"},
        {"create": "App.Scene.Add(Window)", "cleanup": "windowObj.Delete()"},
        {"create": "RegisterSceneEvent", "cleanup": "App.Renderer.UnregisterSceneEvent"}
      ],
      "pattern": {
        "type": "event-driven",
        "architecture": "entity-based-3d-interaction",
        "data_flow": "user-interaction-driven",
        "recommended_patterns": ["wdp-poi-window-interaction", "wdp-perimeter-warning"],
        "key_features": [
          "3D场景实体管理",
          "事件驱动交互",
          "相机聚焦控制",
          "视频窗口动态创建"
        ]
      }
    },
    {
      "id": "ai-robot-inspection",
      "name": "AI 机器人巡检场景",
      "keywords": [
        "机器人巡检",
        "自动巡航",
        "设备监测",
        "异常识别",
        "路径规划",
        "数据采集"
      ],
      "synonyms": [
        "智能巡检",
        "自动化巡检",
        "巡检机器人",
        "移动巡检",
        "轨迹规划",
        "设备巡检"
      ],
      "priority": 10,
      "goal": "让巡检对象沿路径移动，并在关键点联动窗口、状态和相机。",
      "task_breakdown": [
        "创建路径对象或确认已有路径",
        "创建或定位巡检实体",
        "将实体与路径运动能力绑定",
        "根据需要添加相机跟随或聚焦",
        "补充运动结束、停止和清理链路"
      ],
      "primary_skills": [
        "wdp-api-entity-general-behavior"
      ],
      "secondary_skills": [
        "wdp-api-coverings-unified",
        "wdp-api-camera-unified",
        "wdp-api-general-event-registration"
      ],
      "required_clarifications": [
        "路径是新建还是已有",
        "巡检实体的对象类别和对象 Id 来源",
        "是否需要跟车或跟拍",
        "运动结束后是否循环、暂停或清理"
      ],
      "modules": [
        {
          "name": "路径实体模块",
          "wdp_apis": [
            "new App.Path()",
            "pathStyle.type",
            "pathStyle.lineColor",
            "pathStyle.lineWidth"
          ]
        },
        {
          "name": "粒子实体模块",
          "wdp_apis": [
            "new App.Particle()",
            "particleType",
            "particleStyle.scale",
            "particleStyle.rotation"
          ]
        },
        {
          "name": "路径绑定模块",
          "wdp_apis": [
            "new App.Bound()",
            "boundStyle.time",
            "boundStyle.bLoop",
            "boundStyle.speed"
          ]
        },
        {
          "name": "检查点标注模块",
          "wdp_apis": [
            "new App.Poi()",
            "poiStyle.markerNormalUrl",
            "poiStyle.text",
            "poiStyle.textStyle"
          ]
        },
        {
          "name": "数据窗口模块",
          "wdp_apis": [
            "new App.Window()",
            "windowStyle.url",
            "windowStyle.size",
            "windowStyle.followEntity"
          ]
        },
        {
          "name": "场景管理模块",
          "wdp_apis": [
            "App.Scene.Add",
            "App.Scene.Update",
            "App.Scene.Delete",
            "App.Scene.Creates"
          ]
        }
      ],
      "api_flow": [
        {
          "step": 1,
          "description": "批量创建巡检路径和检查点",
          "api": "App.Scene.Creates",
          "params": {
            "entities": [
              {
                "type": "Path",
                "polyline": {
                  "coordinates": "[[121.453, 31.112, 69], [121.477, 31.092, 85], ...]"
                },
                "pathStyle": {
                  "type": "arrow",
                  "lineColor": "#00ff00",
                  "lineWidth": 3
                },
                "customId": "inspection_path_1"
              },
              {
                "type": "Poi",
                "location": "[121.453, 31.112, 69]",
                "poiStyle": {
                  "markerNormalUrl": "checkpoint_icon.png",
                  "text": "检查点A"
                },
                "customId": "checkpoint_A"
              }
            ]
          }
        },
        {
          "step": 2,
          "description": "创建机器人粒子实体",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Particle()",
            "config": {
              "location": "[121.453, 31.112, 69]",
              "particleType": "vehicle_taxi",
              "particleStyle": {
                "scale": 1.5
              },
              "customId": "robot_particle_1"
            }
          }
        },
        {
          "step": 3,
          "description": "绑定机器人到巡检路径",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Bound()",
            "config": {
              "moving": "${robotParticle}",
              "path": "${inspectionPath}",
              "boundStyle": {
                "time": 120,
                "bLoop": false,
                "speed": 1.0
              },
              "customId": "robot_bound_1"
            }
          }
        },
        {
          "step": 4,
          "description": "注册路径移动事件监听",
          "api": "App.Renderer.RegisterSceneEvent",
          "params": {
            "events": [
              {
                "name": "OnBoundMoveEnd",
                "func": "async (ev) => { if(ev.result.customId === 'robot_bound_1') { /* 到达终点，触发数据采集 */ } }"
              }
            ]
          }
        },
        {
          "step": 5,
          "description": "在检查点创建数据采集窗口",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Window()",
            "config": {
              "location": "${checkpointLocation}",
              "windowStyle": {
                "url": "inspection_data.html?pointId=${pointId}",
                "size": "[300, 400]",
                "followEntity": true
              },
              "customId": "data_window_${pointId}"
            }
          }
        },
        {
          "step": 6,
          "description": "更新检查点POI状态",
          "api": "App.Scene.Update",
          "params": {
            "customId": "checkpoint_A",
            "updateData": {
              "poiStyle": {
                "markerNormalUrl": "checkpoint_completed_icon.png",
                "text": "检查点A (已完成)"
              }
            }
          }
        }
      ],
      "data_flow": [
        {
          "step": "App.Scene.Add(Path)",
          "output": "result.object（pathObj）",
          "usage": "作为 Bound 构造函数的路径绑定对象"
        },
        {
          "step": "App.Scene.Add(Particle)",
          "output": "result.object（particleObj）",
          "usage": "作为 Bound 构造函数的移动实体绑定对象"
        },
        {
          "step": "OnBoundMoveEnd 回调",
          "output": "result.customId, result.passedPointIndex",
          "usage": "用于判断到达终点，触发数据采集和状态更新"
        }
      ],
      "cleanup_chain": [
        {"create": "App.Scene.Creates(Path)", "cleanup": "pathObj.Delete()"},
        {"create": "App.Scene.Add(Particle)", "cleanup": "particleObj.Delete()"},
        {"create": "App.Scene.Add(Bound)", "cleanup": "boundObj.Delete()"},
        {"create": "App.Scene.Add(Window)", "cleanup": "windowObj.Delete()"},
        {"create": "RegisterSceneEvent", "cleanup": "UnregisterSceneEvent"}
      ],
      "pattern": {
        "type": "workflow-orchestration",
        "architecture": "entity-path-binding",
        "data_flow": "event-driven-animation",
        "recommended_patterns": ["wdp-path-roam-animation"],
        "key_features": [
          "路径动画控制",
          "实体绑定移动",
          "事件驱动数据采集",
          "动态状态更新",
          "可视化巡检过程"
        ]
      }
    },
    {
      "id": "emergency-command",
      "name": "应急指挥场景",
      "keywords": [
        "应急指挥",
        "事件响应",
        "资源调度",
        "协同处置",
        "态势感知",
        "决策支持"
      ],
      "synonyms": [
        "应急处置",
        "突发事件",
        "应急响应",
        "应急管理",
        "指挥调度",
        "联合指挥"
      ],
      "priority": 10,
      "goal": "展示事件点、影响范围、调度资源、联动窗口与视角。",
      "task_breakdown": [
        "创建事件点位和影响范围",
        "创建调度资源对象",
        "创建路径并驱动资源运动",
        "注册事件联动和状态更新",
        "补充窗口、资源、事件监听的清理链路"
      ],
      "primary_skills": [
        "wdp-api-coverings-unified"
      ],
      "secondary_skills": [
        "wdp-api-entity-general-behavior",
        "wdp-api-camera-unified",
        "wdp-api-general-event-registration"
      ],
      "required_clarifications": [
        "事件点和影响范围的数据来源",
        "调度资源的对象类别和对象 Id 来源",
        "是否需要实时状态更新",
        "离开页面时哪些对象必须清空"
      ],
      "modules": [
        {
          "name": "事件标注模块",
          "wdp_apis": [
            "new App.Poi()",
            "poiStyle.markerNormalUrl",
            "poiStyle.text",
            "poiStyle.textStyle"
          ]
        },
        {
          "name": "资源粒子模块",
          "wdp_apis": [
            "new App.Particle()",
            "particleType",
            "particleStyle.scale",
            "particleStyle.url"
          ]
        },
        {
          "name": "调度路径模块",
          "wdp_apis": [
            "new App.Path()",
            "pathStyle.type",
            "pathStyle.lineColor",
            "pathStyle.lineWidth"
          ]
        },
        {
          "name": "资源移动模块",
          "wdp_apis": [
            "new App.Bound()",
            "boundStyle.time",
            "boundStyle.bLoop",
            "boundStyle.speed"
          ]
        },
        {
          "name": "态势范围模块",
          "wdp_apis": [
            "new App.Range()",
            "rangeStyle.fillColor",
            "rangeStyle.outlineColor",
            "rangeStyle.height"
          ]
        },
        {
          "name": "信息窗口模块",
          "wdp_apis": [
            "new App.Window()",
            "windowStyle.url",
            "windowStyle.size",
            "windowStyle.followEntity"
          ]
        },
        {
          "name": "场景管理模块",
          "wdp_apis": [
            "App.Scene.Add",
            "App.Scene.Update",
            "App.Scene.Delete",
            "App.Scene.Creates"
          ]
        },
        {
          "name": "相机控制模块",
          "wdp_apis": [
            "App.CameraControl.FocusByLocation",
            "App.CameraControl.FocusByCustomId",
            "App.CameraControl.SetCameraPose"
          ]
        }
      ],
      "api_flow": [
        {
          "step": 1,
          "description": "批量创建应急事件标注和影响范围",
          "api": "App.Scene.Creates",
          "params": {
            "entities": [
              {
                "type": "Poi",
                "location": "[116.4074, 39.9042, 50]",
                "poiStyle": {
                  "markerNormalUrl": "fire_emergency_icon.png",
                  "text": "火灾事件"
                },
                "customId": "emergency_event_1"
              },
              {
                "type": "Range",
                "polygon": {
                  "coordinates": "[[116.407, 39.904], [116.408, 39.904], ...]"
                },
                "rangeStyle": {
                  "fillColor": "rgba(255, 0, 0, 0.2)",
                  "outlineColor": "#ff0000",
                  "height": 100
                },
                "customId": "danger_zone_1"
              }
            ]
          }
        },
        {
          "step": 2,
          "description": "创建应急资源粒子实体",
          "api": "App.Scene.Creates",
          "params": {
            "entities": [
              {
                "type": "Particle",
                "location": "[116.400, 39.900, 0]",
                "particleType": "vehicle_fire_truck",
                "particleStyle": {
                  "scale": 1.2
                },
                "customId": "fire_truck_1"
              }
            ]
          }
        },
        {
          "step": 3,
          "description": "规划资源调度路径",
          "api": "App.Scene.Creates",
          "params": {
            "entities": [
              {
                "type": "Path",
                "polyline": {
                  "coordinates": "[[116.400, 39.900, 0], [116.4074, 39.9042, 0]]"
                },
                "pathStyle": {
                  "type": "arrow",
                  "lineColor": "#ff6600",
                  "lineWidth": 4
                },
                "customId": "dispatch_path_1"
              }
            ]
          }
        },
        {
          "step": 4,
          "description": "绑定资源到调度路径",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Bound()",
            "config": {
              "moving": "${fireTruckParticle}",
              "path": "${dispatchPath}",
              "boundStyle": {
                "time": 60,
                "bLoop": false,
                "speed": 1.5
              },
              "customId": "resource_bound_1"
            }
          }
        },
        {
          "step": 5,
          "description": "聚焦到应急事件位置",
          "api": "App.CameraControl.FocusByLocation",
          "params": {
            "location": "[116.4074, 39.9042, 50]",
            "duration": 1000,
            "pitch": -60,
            "yaw": 0
          }
        },
        {
          "step": 6,
          "description": "创建态势信息窗口",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Window()",
            "config": {
              "location": "[116.4074, 39.9042, 50]",
              "windowStyle": {
                "url": "emergency_dashboard.html?eventId=event_1",
                "size": "[400, 500]",
                "offset": "[0, 2]"
              },
              "customId": "situation_window_1"
            }
          }
        },
        {
          "step": 7,
          "description": "注册资源到达事件",
          "api": "App.Renderer.RegisterSceneEvent",
          "params": {
            "events": [
              {
                "name": "OnBoundMoveEnd",
                "func": "async (ev) => { if(ev.result.customId.startsWith('resource_bound')) { /* 资源到达，更新状态 */ } }"
              }
            ]
          }
        },
        {
          "step": 8,
          "description": "更新事件状态标注",
          "api": "App.Scene.Update",
          "params": {
            "customId": "emergency_event_1",
            "updateData": {
              "poiStyle": {
                "markerNormalUrl": "fire_controlled_icon.png",
                "text": "火灾事件 (处置中)"
              }
            }
          }
        }
      ],
      "data_flow": [
        {
          "step": "App.Scene.Creates",
          "output": "result.objects（含 eid, customId, location）",
          "usage": "缓存用于清理和后续更新"
        },
        {
          "step": "OnBoundMoveEnd 回调",
          "output": "result.customId",
          "usage": "用于判断资源到达，触发状态更新"
        }
      ],
      "cleanup_chain": [
        {"create": "App.Scene.Creates(POI/Range)", "cleanup": "Delete(customId)"},
        {"create": "App.Scene.Creates(Particle)", "cleanup": "particleObj.Delete()"},
        {"create": "App.Scene.Add(Bound)", "cleanup": "boundObj.Delete()"},
        {"create": "App.Scene.Add(Window)", "cleanup": "windowObj.Delete()"},
        {"create": "RegisterSceneEvent", "cleanup": "UnregisterSceneEvent"}
      ],
      "pattern": {
        "type": "command-control",
        "architecture": "real-time-3d-visualization",
