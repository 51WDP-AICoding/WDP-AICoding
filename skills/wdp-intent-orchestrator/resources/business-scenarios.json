          "params": {
            "rules": "见 selection_rules"
          }
        },
        {
          "step": 2,
          "description": "创建网格区域（Range 或 GeoLayer）",
          "api": "App.Scene.Add",
          "params": {
            "range_branch": "CreateGeometryFromGeoJson/CreateGeometryFromShapefile/coordinates -> new App.Range() -> App.Scene.Add",
            "gis_branch": "App.Plugin.Install(GisApi) -> new App.GeoLayer() -> App.Scene.Add"
          }
        },
        {
          "step": 3,
          "description": "创建巡检路径（路径透明但可参与绑定移动）",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Path()",
            "config": {
              "pathStyle": {
                "opacity": 0,
                "lineWidth": 1
              },
              "constraint": "path_in_geojson_grid"
            }
          }
        },
        {
          "step": 4,
          "description": "创建地面机器人与无人机实体",
          "api": "App.Scene.Add",
