          "params": {
            "events": [
              "OnEntityClicked",
              "OnBoundMoveEnd"
            ]
          }
        },
        {
          "step": 7,
          "description": "在事件回调中创建窗口并相机聚焦（失败时降级SetCameraPose）",
          "api": "App.CameraControl.Focus",
          "params": {
            "fallback": "App.CameraControl.SetCameraPose"
          }
        }
      ],
      "selection_rules": {
        "architecture_routing": [
          {
            "condition": "用户提示词包含 GIS/GisApi/GeoLayer",
            "route_to": "gis-geolayer"
          },
          {
            "condition": "用户提示词包含 Range/围栏/周界 或已给出区域轮廓坐标",
            "route_to": "wdp-range"
          },
          {
            "condition": "未显式指定架构",
            "route_to": "wdp-range"
          }
        ],
        "range_data_source_rules": [
          {
            "condition": "提示词包含 GeoJson/geojson 或提供 .geojson 尾缀地址",
            "source_type": "geojson_file",
            "api_path": "App.Scene.CreateGeometryFromGeoJson -> new App.Range -> App.Scene.Add"
          },
          {
            "condition": "提示词包含 shp/shapefile 或提供 .shp 尾缀地址",
            "source_type": "shp_file",
            "api_path": "App.DataModel.Geometry.CreateGeometryFromShapefile -> new App.Range -> App.Scene.Add"
          },
          {
            "condition": "提示词提供区域轮廓坐标（polygon/coordinates）",
            "source_type": "coordinates",
            "api_path": "new App.Range(polygon2D.coordinates) -> App.Scene.Add"
          }
        ],
        "range_fill_area_type_rules": [
          {
            "condition": "提示词明确包含 '网格'",
            "fillAreaType": "block"
          },
          {
            "condition": "提示词包含 '网格栅栏' 或 '网格周界'",
            "fillAreaType": "grid"
          }
        ]
      },
      "pattern": {
        "type": "grid-patrol",
