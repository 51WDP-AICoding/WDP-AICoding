          "description": "通过Bound绑定实体与路径进行巡检运动",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Bound()",
            "config": {
              "moving": "${uavOrRobot}",
              "path": "${gridPath}"
            }
          }
        },
        {
          "step": 6,
          "description": "注册巡检事件并联动窗口与相机",
