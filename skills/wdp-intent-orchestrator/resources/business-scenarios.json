{
  "scenarios": [
    {
      "id": "video-perimeter-monitoring",
      "name": "视频周界场景",
      "keywords": [
        "视频监控",
        "周界防护",
        "入侵检测",
        "实时告警",
        "视频分析",
        "AI识别"
      ],
      "modules": [
        {
          "name": "场景实体模块",
          "wdp_apis": [
            "App.Scene.Add",
            "App.Scene.Update",
            "App.Scene.Delete",
            "App.Scene.Creates"
          ]
        },
        {
          "name": "POI标注模块",
          "wdp_apis": [
            "new App.Poi()",
            "poiStyle.markerNormalUrl",
            "poiStyle.markerSelectUrl",
            "poiStyle.text"
          ]
        },
        {
          "name": "周界围栏模块",
          "wdp_apis": [
            "new App.Range()",
            "rangeStyle.fillColor",
            "rangeStyle.outlineColor",
            "rangeStyle.height"
          ]
        },
        {
          "name": "视频窗口模块",
          "wdp_apis": [
            "new App.Window()",
            "windowStyle.url",
            "windowStyle.size",
            "windowStyle.offset"
          ]
        },
        {
          "name": "事件交互模块",
          "wdp_apis": [
            "App.Renderer.RegisterSceneEvent",
            "OnWdpSceneIsReady",
            "OnEntityClick",
            "OnEntityMouseEnter"
          ]
        },
        {
          "name": "相机控制模块",
          "wdp_apis": [
            "App.CameraControl.FocusByCustomId",
            "App.CameraControl.FocusByLocation",
            "App.CameraControl.SetCameraPosture"
          ]
        }
      ],
      "api_flow": [
        {
          "step": 1,
          "description": "批量创建AI摄像头POI标注",
          "api": "App.Scene.Creates",
          "params": {
            "entities": [
              {
                "type": "Poi",
                "location": "[121.464, 31.224, 47]",
                "poiStyle": {
                  "markerNormalUrl": "camera_icon.png",
                  "text": "AI摄像头1"
                },
                "customId": "camera_poi_1"
              }
            ],
            "options": {
              "calculateCoordZ": {
                "coordZRef": "surface",
                "coordZOffset": 2
              }
            }
          }
        },
        {
          "step": 2,
          "description": "创建周界围栏区域",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Range()",
            "config": {
              "polygon": {
                "coordinates": "[[121.464, 31.224], [121.465, 31.224], ...]"
              },
              "rangeStyle": {
                "fillColor": "rgba(255, 0, 0, 0.3)",
                "outlineColor": "#ff0000",
                "height": 50
              },
              "customId": "perimeter_zone_1"
            }
          }
        },
        {
          "step": 3,
          "description": "注册POI点击事件",
          "api": "App.Renderer.RegisterSceneEvent",
          "params": {
            "events": [
              {
                "name": "OnEntityClick",
                "func": "async (ev) => { if(ev.result.customId.startsWith('camera_poi')) { /* 聚焦相机并显示视频窗口 */ } }"
              }
            ]
          }
        },
        {
          "step": 4,
          "description": "聚焦到选中的摄像头",
          "api": "App.CameraControl.FocusByCustomId",
          "params": {
            "customId": "${clickedPoiId}",
            "duration": 500,
            "pitch": -69,
            "yaw": 176
          }
        },
        {
          "step": 5,
          "description": "创建视频流窗口",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Window()",
            "config": {
              "location": "${cameraLocation}",
              "windowStyle": {
                "url": "video_stream.html?cameraId=${cameraId}",
                "size": "[250, 190]",
                "offset": "[0, 1.7]"
              },
              "customId": "video_window_${cameraId}"
            }
          }
        }
      ],
      "pattern": {
        "type": "event-driven",
        "architecture": "entity-based-3d-interaction",
        "data_flow": "user-interaction-driven",
        "key_features": [
          "3D场景实体管理",
          "事件驱动交互",
          "相机聚焦控制",
          "视频窗口动态创建"
        ]
      }
    },
    {
      "id": "ai-robot-inspection",
      "name": "AI 机器人巡检场景",
      "keywords": [
        "机器人巡检",
        "自动巡航",
        "设备监测",
        "异常识别",
        "路径规划",
        "数据采集"
      ],
      "modules": [
        {
          "name": "路径实体模块",
          "wdp_apis": [
            "new App.Path()",
            "pathStyle.type",
            "pathStyle.lineColor",
            "pathStyle.lineWidth"
          ]
        },
        {
          "name": "粒子实体模块",
          "wdp_apis": [
            "new App.Particle()",
            "particleType",
            "particleStyle.scale",
            "particleStyle.rotation"
          ]
        },
        {
          "name": "路径绑定模块",
          "wdp_apis": [
            "new App.Bound()",
            "boundStyle.time",
            "boundStyle.bLoop",
            "boundStyle.speed"
          ]
        },
        {
          "name": "检查点标注模块",
          "wdp_apis": [
            "new App.Poi()",
            "poiStyle.markerNormalUrl",
            "poiStyle.text",
            "poiStyle.textStyle"
          ]
        },
        {
          "name": "数据窗口模块",
          "wdp_apis": [
            "new App.Window()",
            "windowStyle.url",
            "windowStyle.size",
            "windowStyle.followEntity"
          ]
        },
        {
          "name": "场景管理模块",
          "wdp_apis": [
            "App.Scene.Add",
            "App.Scene.Update",
            "App.Scene.Delete",
            "App.Scene.Creates"
          ]
        }
      ],
      "api_flow": [
        {
          "step": 1,
          "description": "批量创建巡检路径和检查点",
          "api": "App.Scene.Creates",
          "params": {
            "entities": [
              {
                "type": "Path",
                "polyline": {
                  "coordinates": "[[121.453, 31.112, 69], [121.477, 31.092, 85], ...]"
                },
                "pathStyle": {
                  "type": "arrow",
                  "lineColor": "#00ff00",
                  "lineWidth": 3
                },
                "customId": "inspection_path_1"
              },
              {
                "type": "Poi",
                "location": "[121.453, 31.112, 69]",
                "poiStyle": {
                  "markerNormalUrl": "checkpoint_icon.png",
                  "text": "检查点A"
                },
                "customId": "checkpoint_A"
              }
            ]
          }
        },
        {
          "step": 2,
          "description": "创建机器人粒子实体",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Particle()",
            "config": {
              "location": "[121.453, 31.112, 69]",
              "particleType": "vehicle_taxi",
              "particleStyle": {
                "scale": 1.5
              },
              "customId": "robot_particle_1"
            }
          }
        },
        {
          "step": 3,
          "description": "绑定机器人到巡检路径",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Bound()",
            "config": {
              "moving": "${robotParticle}",
              "path": "${inspectionPath}",
              "boundStyle": {
                "time": 120,
                "bLoop": false,
                "speed": 1.0
              },
              "customId": "robot_bound_1"
            }
          }
        },
        {
          "step": 4,
          "description": "注册路径移动事件监听",
          "api": "App.Renderer.RegisterSceneEvent",
          "params": {
            "events": [
              {
                "name": "OnBoundMoveEnd",
                "func": "async (ev) => { if(ev.result.customId === 'robot_bound_1') { /* 到达终点，触发数据采集 */ } }"
              }
            ]
          }
        },
        {
          "step": 5,
          "description": "在检查点创建数据采集窗口",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Window()",
            "config": {
              "location": "${checkpointLocation}",
              "windowStyle": {
                "url": "inspection_data.html?pointId=${pointId}",
                "size": "[300, 400]",
                "followEntity": true
              },
              "customId": "data_window_${pointId}"
            }
          }
        },
        {
          "step": 6,
          "description": "更新检查点POI状态",
          "api": "App.Scene.Update",
          "params": {
            "customId": "checkpoint_A",
            "updateData": {
              "poiStyle": {
                "markerNormalUrl": "checkpoint_completed_icon.png",
                "text": "检查点A (已完成)"
              }
            }
          }
        }
      ],
      "pattern": {
        "type": "workflow-orchestration",
        "architecture": "entity-path-binding",
        "data_flow": "event-driven-animation",
        "key_features": [
          "路径动画控制",
          "实体绑定移动",
          "事件驱动数据采集",
          "动态状态更新",
          "可视化巡检过程"
        ]
      }
    },
    {
      "id": "emergency-command",
      "name": "应急指挥场景",
      "keywords": [
        "应急指挥",
        "事件响应",
        "资源调度",
        "协同作战",
        "态势感知",
        "决策支持"
      ],
      "modules": [
        {
          "name": "事件标注模块",
          "wdp_apis": [
            "new App.Poi()",
            "poiStyle.markerNormalUrl",
            "poiStyle.text",
            "poiStyle.textStyle"
          ]
        },
        {
          "name": "资源粒子模块",
          "wdp_apis": [
            "new App.Particle()",
            "particleType",
            "particleStyle.scale",
            "particleStyle.url"
          ]
        },
        {
          "name": "调度路径模块",
          "wdp_apis": [
            "new App.Path()",
            "pathStyle.type",
            "pathStyle.lineColor",
            "pathStyle.lineWidth"
          ]
        },
        {
          "name": "资源移动模块",
          "wdp_apis": [
            "new App.Bound()",
            "boundStyle.time",
            "boundStyle.bLoop",
            "boundStyle.speed"
          ]
        },
        {
          "name": "态势范围模块",
          "wdp_apis": [
            "new App.Range()",
            "rangeStyle.fillColor",
            "rangeStyle.outlineColor",
            "rangeStyle.height"
          ]
        },
        {
          "name": "信息窗口模块",
          "wdp_apis": [
            "new App.Window()",
            "windowStyle.url",
            "windowStyle.size",
            "windowStyle.followEntity"
          ]
        },
        {
          "name": "场景管理模块",
          "wdp_apis": [
            "App.Scene.Add",
            "App.Scene.Update",
            "App.Scene.Delete",
            "App.Scene.Creates"
          ]
        },
        {
          "name": "相机控制模块",
          "wdp_apis": [
            "App.CameraControl.FocusByLocation",
            "App.CameraControl.FocusByCustomId",
            "App.CameraControl.SetCameraPosture"
          ]
        }
      ],
      "api_flow": [
        {
          "step": 1,
          "description": "批量创建应急事件标注和影响范围",
          "api": "App.Scene.Creates",
          "params": {
            "entities": [
              {
                "type": "Poi",
                "location": "[116.4074, 39.9042, 50]",
                "poiStyle": {
                  "markerNormalUrl": "fire_emergency_icon.png",
                  "text": "火灾事件",
                  "textStyle": {
                    "color": "#ff0000",
                    "fontSize": 16
                  }
                },
                "customId": "emergency_event_1"
              },
              {
                "type": "Range",
                "polygon": {
                  "coordinates": "[[116.407, 39.904], [116.408, 39.904], ...]"
                },
                "rangeStyle": {
                  "fillColor": "rgba(255, 0, 0, 0.2)",
                  "outlineColor": "#ff0000",
                  "height": 100
                },
                "customId": "danger_zone_1"
              }
            ]
          }
        },
        {
          "step": 2,
          "description": "创建应急资源粒子实体",
          "api": "App.Scene.Creates",
          "params": {
            "entities": [
              {
                "type": "Particle",
                "location": "[116.400, 39.900, 0]",
                "particleType": "vehicle_fire_truck",
                "particleStyle": {
                  "scale": 1.2
                },
                "customId": "fire_truck_1"
              },
              {
                "type": "Particle",
                "location": "[116.410, 39.910, 0]",
                "particleType": "vehicle_ambulance",
                "particleStyle": {
                  "scale": 1.2
                },
                "customId": "ambulance_1"
              }
            ]
          }
        },
        {
          "step": 3,
          "description": "规划资源调度路径",
          "api": "App.Scene.Creates",
          "params": {
            "entities": [
              {
                "type": "Path",
                "polyline": {
                  "coordinates": "[[116.400, 39.900, 0], [116.4074, 39.9042, 0]]"
                },
                "pathStyle": {
                  "type": "arrow",
                  "lineColor": "#ff6600",
                  "lineWidth": 4
                },
                "customId": "dispatch_path_1"
              }
            ]
          }
        },
        {
          "step": 4,
          "description": "绑定资源到调度路径",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Bound()",
            "config": {
              "moving": "${fireTruckParticle}",
              "path": "${dispatchPath}",
              "boundStyle": {
                "time": 60,
                "bLoop": false,
                "speed": 1.5
              },
              "customId": "resource_bound_1"
            }
          }
        },
        {
          "step": 5,
          "description": "聚焦到应急事件位置",
          "api": "App.CameraControl.FocusByLocation",
          "params": {
            "location": "[116.4074, 39.9042, 50]",
            "duration": 1000,
            "pitch": -60,
            "yaw": 0
          }
        },
        {
          "step": 6,
          "description": "创建态势信息窗口",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Window()",
            "config": {
              "location": "[116.4074, 39.9042, 50]",
              "windowStyle": {
                "url": "emergency_dashboard.html?eventId=event_1",
                "size": "[400, 500]",
                "offset": "[0, 2]"
              },
              "customId": "situation_window_1"
            }
          }
        },
        {
          "step": 7,
          "description": "注册资源到达事件",
          "api": "App.Renderer.RegisterSceneEvent",
          "params": {
            "events": [
              {
                "name": "OnBoundMoveEnd",
                "func": "async (ev) => { if(ev.result.customId.startsWith('resource_bound')) { /* 资源到达，更新状态 */ } }"
              }
            ]
          }
        },
        {
          "step": 8,
          "description": "更新事件状态标注",
          "api": "App.Scene.Update",
          "params": {
            "customId": "emergency_event_1",
            "updateData": {
              "poiStyle": {
                "markerNormalUrl": "fire_controlled_icon.png",
                "text": "火灾事件 (处置中)",
                "textStyle": {
                  "color": "#ff9900"
                }
              }
            }
          }
        }
      ],
      "pattern": {
        "type": "command-control",
        "architecture": "real-time-3d-visualization",
        "data_flow": "event-driven-spatial",
        "key_features": [
          "3D态势可视化",
          "实时资源调度",
          "路径动画展示",
          "事件状态追踪",
          "空间范围标注",
          "相机智能聚焦"
        ]
      }
    },
    {
      "id": "fire-alert-incident",
      "name": "火情告警场景",
      "keywords": [
        "火灾",
        "火情",
        "防火",
        "火情演练",
        "着火",
        "燃烧",
        "火灾扑救",
        "火情告警",
        "森林防火"
      ],
      "modules": [
        {
          "name": "火情特效模块",
          "wdp_apis": [
            "new App.Particle()",
            "App.Scene.Add",
            "App.Scene.Update"
          ],
          "purpose": "创建并更新火情特效，默认 particleType=flame"
        },
        {
          "name": "告警POI模块",
          "wdp_apis": [
            "new App.Poi()",
            "App.Scene.Add",
            "App.Scene.Update"
          ],
          "purpose": "创建火情告警点位并承载交互入口"
        },
        {
          "name": "3D文字标注模块",
          "wdp_apis": [
            "new App.Text3D()",
            "App.Scene.Add",
            "App.Scene.Update"
          ],
          "purpose": "展示火情等级、状态与处置信息"
        },
        {
          "name": "视频监控窗口模块",
          "wdp_apis": [
            "new App.Window()",
            "App.Scene.Add",
            "App.Scene.Update"
          ],
          "purpose": "告警触发时展示现场视频监控窗口"
        },
        {
          "name": "镜头聚焦模块",
          "wdp_apis": [
            "App.CameraControl.Focus",
            "App.CameraControl.SetCameraPose"
          ],
          "purpose": "对火情点位进行相机聚焦与失败降级"
        },
        {
          "name": "事件联动模块",
          "wdp_apis": [
            "App.Renderer.RegisterSceneEvent",
            "OnWdpSceneIsReady",
            "OnEntityClicked"
          ],
          "purpose": "场景就绪门禁与告警对象点击联动"
        },
        {
          "name": "其它兜底模块",
          "wdp_apis": [
            "App.Scene.Add",
            "App.Renderer.RegisterSceneEvent",
            "App.Scene.Update",
            "App.Scene.Delete"
          ],
          "purpose": "未覆盖子需求的通用兜底处理"
        }
      ],
      "api_flow": [
        {
          "step": 1,
          "description": "等待场景就绪后再执行业务链路",
          "api": "App.Renderer.RegisterSceneEvent",
          "params": {
            "events": [
              "OnWdpSceneIsReady"
            ]
          }
        },
        {
          "step": 2,
          "description": "创建火情特效与告警点位",
          "api": "App.Scene.Add",
          "params": {
            "entities": [
              "new App.Particle()",
              "new App.Poi()"
            ],
            "particleStyle": {
              "particleType": "flame"
            }
          }
        },
        {
          "step": 3,
          "description": "创建3D文字展示火情等级与状态",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Text3D()"
          }
        },
        {
          "step": 4,
          "description": "注册告警对象点击联动事件",
          "api": "App.Renderer.RegisterSceneEvent",
          "params": {
            "events": [
              "OnEntityClicked"
            ]
          }
        },
        {
          "step": 5,
          "description": "点击后创建视频窗口",
          "api": "App.Scene.Add",
          "params": {
            "entity": "new App.Window()"
          }
        },
        {
          "step": 6,
          "description": "点击后相机聚焦到火情点位",
          "api": "App.CameraControl.Focus",
          "params": {
            "fallback": "App.CameraControl.SetCameraPose"
          }
        },
        {
          "step": 7,
          "description": "更新火情状态与可视化标识",
          "api": "App.Scene.Update",
          "params": {
            "target": "particle/poi/text3d/window"
          }
        }
      ],
      "pattern": {
        "type": "fire-alert-response",
        "architecture": "event-driven-emergency-command",
        "data_flow": "realtime-alert-linked-visualization",
        "key_features": [
          "火情特效（flame）",
          "告警POI点击联动",
          "3D文字状态提示",
          "视频监控窗口联动",
          "相机聚焦与降级",
          "其它兜底处理"
        ]
      }
    },
    {
      "id": "scenic-shuttle-operations",
      "name": "景区态势-接驳运力-班车运行场景",
      "keywords": [
        "景区态势",
