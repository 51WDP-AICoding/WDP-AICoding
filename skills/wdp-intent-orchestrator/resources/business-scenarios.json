        {"create": "App.Scene.Add(Bound)", "cleanup": "boundObj.Delete()"},
        {"create": "App.Scene.Add(Window)", "cleanup": "windowObj.Delete()"},
        {"create": "RegisterSceneEvent", "cleanup": "UnregisterSceneEvent"}
