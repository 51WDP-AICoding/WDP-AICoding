{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "wdp-context-memory-schema",
  "title": "WDP Context Memory Schema",
  "description": "结构化状态管理Schema，用于WDP技能库的上下文一致性维护",
  "version": "1.0.0",
  
  "definitions": {
    "Vector3": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 3,
      "maxItems": 3,
      "description": "三维坐标/向量 [x, y, z]"
    },
    "Rotator": {
      "type": "object",
      "description": "相机旋转（WDP相机只有pitch和yaw）",
      "properties": {
        "pitch": { "type": "number", "description": "俯仰角(度)，范围[-90, 0]" },
        "yaw": { "type": "number", "description": "偏航角(度)，范围[-180, 180]" }
      },
      "required": ["pitch", "yaw"]
    },
    "EntityRef": {
      "type": "object",
      "description": "实体引用",
      "properties": {
        "eid": { "type": "string", "description": "实体唯一标识" },
        "entityName": { "type": "string", "description": "实体名称" },
        "customId": { "type": "string", "description": "自定义ID" },
        "type": { 
          "type": "string", 
          "enum": [
            "HierarchyMeshEntity",
            "Tile", 
            "AESTiles",
            "RealTimeVideo",
            "Window",
            "Poi",
            "Particle",
            "Text3D",
            "Viewshed",
            "Path",
            "Parabola",
            "Range",
            "HeatMap",
            "ColumnarHeatMap",
            "SpaceHeatMap",
            "RoadHeatMap",
            "StaticModel",
            "SkeletalModel",
            "Camera",
            "CameraRoam"
          ],
          "description": "实体类型：覆盖物、模型、相机等" 
        }
      },
      "required": ["eid", "type"]
    }
  },

  "type": "object",
  "properties": {
    "_meta": {
      "type": "object",
      "description": "元信息",
      "properties": {
        "taskId": { "type": "string", "description": "当前任务ID" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "storagePath": { "type": "string", "description": "持久化存储路径" },
        "version": { "type": "string", "default": "1.0.0" }
      }
    },

    "transient": {
      "type": "object",
      "description": "【瞬时工作区/Hot Memory】高频读写，随操作快速更新",
      "properties": {
        "selection": {
          "type": "object",
          "description": "当前选中对象（支持多种选择类型：实体/BIM构件/GIS要素/材质）",
          "properties": {
            "entity": { 
              "$ref": "#/definitions/EntityRef",
              "description": "选中的实体引用"
            },
            "nodeId": { 
              "type": "string", 
              "description": "BIM构件Node ID 或 AESTiles单体ID（通过 FocusToNodes 获取）" 
            },
            "featureId": { 
              "type": "string", 
              "description": "GIS要素ID（通过 OnGeoLayerFeatureClicked 获取）" 
            },
            "materialIndex": { 
              "type": "number", 
              "description": "材质索引（通过 OnWdpMaterialHit 获取）" 
            },
            "meshName": { 
              "type": "string", 
              "description": "网格名称（通过 OnWdpMaterialHit 获取）" 
            },
            "screenPosition": { 
              "type": "object", 
              "description": "屏幕坐标位置",
              "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" }
              }
            },
            "worldPosition": {
              "$ref": "#/definitions/Vector3",
              "description": "世界坐标位置（拾取时计算）"
            },
            "selectionType": {
              "type": "string",
              "enum": ["entity", "bimNode", "gisFeature", "material", "none"],
              "description": "选择类型标识，用于区分不同选择来源"
            }
          }
        },
        "camera": {
          "type": "object",
          "description": "当前相机参数（基于 official-scene-camera.md）",
          "properties": {
            "location": { 
              "$ref": "#/definitions/Vector3",
              "description": "相机位置 [lng, lat, z]"
            },
            "rotation": { 
              "$ref": "#/definitions/Rotator",
              "description": "相机旋转 {pitch, yaw}"
            },
            "locationLimit": {
              "type": "array",
              "description": "位置区域限制（多边形顶点数组）",
              "items": { "$ref": "#/definitions/Vector3" }
            },
            "pitchLimit": {
              "type": "array",
              "description": "俯仰角限制范围",
              "minItems": 2,
              "maxItems": 2,
              "items": { "type": "number" },
              "default": [-90, 0]
            },
            "yawLimit": {
              "type": "array",
              "description": "偏航角限制范围",
              "minItems": 2,
              "maxItems": 2,
              "items": { "type": "number" },
              "default": [-180, 180]
            },
            "viewDistanceLimit": {
              "type": "array",
              "description": "视距范围限制（单位：米）",
              "minItems": 2,
              "maxItems": 2,
              "items": { "type": "number" },
              "default": [0, 10000]
            },
            "fieldOfView": {
              "type": "number",
              "description": "相机视锥横向视角",
              "minimum": 0,
              "maximum": 120,
              "default": 90
            },
            "controlMode": {
              "type": "string",
              "description": "相机控制模式",
              "enum": ["RTS", "TPS", "FPS"],
              "default": "RTS"
            },
            "zoom": { 
              "type": "number",
              "description": "缩放级别（已废弃，使用 viewDistanceLimit）"
            },
            "distanceFactor": { 
              "type": "number",
              "description": "距离因子（聚焦时使用）" 
            }
          },
          "required": ["location", "rotation"]
        },
        "lastApiCall": {
          "type": "object",
          "description": "上一次API调用记录",
          "properties": {
            "method": { "type": "string", "description": "API方法名" },
            "params": { "type": "object" },
            "response": { 
              "type": "object",
              "properties": {
                "success": { "type": "boolean" },
                "message": { "type": "string" },
                "timestamp": { "type": "string" }
              }
            },
            "timestamp": { "type": "string" }
          }
        },
        "interactionMode": {
          "type": "string",
          "enum": ["select", "move", "rotate", "scale", "measure", "section", "none"],
          "description": "当前交互模式"
        },
        "eventRegistry": {
          "type": "array",
          "description": "已注册的事件处理器清单（防止重复注册和内存泄漏）",
          "items": {
            "type": "object",
            "properties": {
              "eventName": { 
                "type": "string", 
                "description": "事件名称",
                "enum": [
                  "OnWdpClick",
                  "OnWdpDoubleClick",
                  "OnWdpMouseMove",
                  "OnWdpMouseDown",
                  "OnWdpMouseUp",
                  "OnSelectionChanged",
                  "OnCameraChanged",
                  "OnCameraMoveEnd",
                  "OnGeoLayerFeatureClicked",
                  "OnWdpMaterialHit",
                  "OnSceneReady",
                  "OnSceneClose",
                  "OnRendererDisconnected"
                ]
              },
              "handlerId": { 
                "type": "string", 
                "description": "处理器唯一标识（通常使用随机字符串或时间戳）" 
              },
              "options": { 
                "type": "object", 
                "description": "事件注册选项（如 triggerType, selectionType 等）" 
              },
              "registeredAt": { 
                "type": "string", 
                "format": "date-time",
                "description": "注册时间戳" 
              },
              "isActive": {
                "type": "boolean",
                "description": "是否处于激活状态",
                "default": true
              }
            },
            "required": ["eventName", "handlerId", "registeredAt"]
          }
        },
        "materialPicking": {
          "type": "object",
          "description": "材质拾取状态（通过 OnWdpMaterialHit 事件获取）",
          "properties": {
            "entity": {
              "$ref": "#/definitions/EntityRef",
              "description": "被拾取材质的实体"
            },
            "materialIndex": {
              "type": "number",
              "description": "材质索引（子构件/材质面标识）"
            },
            "meshName": {
              "type": "string",
              "description": "网格名称（子构件标识）"
            },
            "hitLocation": {
              "$ref": "#/definitions/Vector3",
              "description": "拾取点的世界坐标位置"
            },
            "screenPosition": {
              "type": "object",
              "description": "拾取点的屏幕坐标",
              "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" }
              }
            },
            "pickedAt": {
              "type": "string",
              "format": "date-time",
              "description": "拾取时间戳"
            }
          },
          "required": ["entity", "materialIndex", "meshName"]
        },
        "cameraRoam": {
          "type": "object",
          "description": "相机漫游状态",
          "properties": {
            "roamId": {
              "type": "string",
              "description": "漫游对象ID"
            },
            "status": {
              "type": "string",
              "description": "漫游状态",
              "enum": ["idle", "playing", "paused", "stopped"],
              "default": "idle"
            },
            "progressRatio": {
              "type": "number",
              "description": "当前漫游进度比例 [0,1]",
              "minimum": 0,
              "maximum": 1,
              "default": 0
            },
            "speedRatio": {
              "type": "number",
              "description": "漫游速度倍率",
              "default": 1
            },
            "bReverse": {
              "type": "boolean",
              "description": "是否反向播放",
              "default": false
            },
            "frames": {
              "type": "array",
              "description": "漫游关键帧列表",
              "items": {
                "type": "object",
                "properties": {
                  "location": { "$ref": "#/definitions/Vector3" },
                  "rotation": { "$ref": "#/definitions/Rotator" },
                  "time": { "type": "number", "description": "到下一帧的时间(秒)" }
                }
              }
            }
          }
        },
        "cameraFollow": {
          "type": "object",
          "description": "相机跟随状态",
          "properties": {
            "targetEntity": {
              "$ref": "#/definitions/EntityRef",
              "description": "被跟随的目标实体"
            },
            "followRotation": {
              "type": "object",
              "description": "跟随时的相机旋转角度",
              "properties": {
                "pitch": { "type": "number" },
                "yaw": { "type": "number" }
              }
            },
            "useRelativeRotation": {
              "type": "boolean",
              "description": "是否使用相对旋转",
              "default": true
            },
            "distance": {
              "type": "number",
              "description": "相机与目标的距离（米）"
            },
            "bFPS": {
              "type": "boolean",
              "description": "true=第一人称视角, false=第三人称视角",
              "default": false
            }
          }
        },
        "measurement": {
          "type": "object",
          "description": "测量工具状态",
          "properties": {
            "active": { "type": "boolean", "description": "测量是否激活", "default": false },
            "measureType": { "type": "string", "enum": ["distance", "area", "angle", "height"], "description": "测量类型" },
            "points": { "type": "array", "description": "测量点列表", "items": { "$ref": "#/definitions/Vector3" } },
            "result": { "type": "number", "description": "测量结果值" },
            "unit": { "type": "string", "description": "单位（如'm','m²'）" }
          }
        },
        "tools": {
          "type": "object",
          "description": "当前激活的工具状态",
          "properties": {
            "activeTool": { "type": "string", "enum": ["picker", "measure", "section", "roam", "none"], "description": "当前工具" },
            "toolConfig": { "type": "object", "description": "工具配置参数" }
          }
        },
        "rectangleSelection": {
          "type": "object",
          "description": "框选状态（通过 PickAesTilesNodesByRectangle）",
          "properties": {
            "active": { "type": "boolean", "description": "框选是否进行中" },
            "startScreenPos": { "type": "object", "properties": { "x": "number", "y": "number" } },
            "endScreenPos": { "type": "object", "properties": { "x": "number", "y": "number" } },
            "selectedNodeIds": { "type": "array", "items": "string", "description": "选中的Node ID列表" }
          }
        }
      }
    },

    "spatial": {
      "type": "object",
      "description": "【空间与环境上下文/Warm Memory】跨指令有效，场景重置时变更",
      "properties": {
        "coordinateSystem": {
          "type": "string",
          "enum": ["global", "local", "relative"],
          "default": "global",
          "description": "当前坐标系参考"
        },
        "sceneOrigin": {
          "type": "object",
          "description": "场景原点/锚点",
          "properties": {
            "location": { "$ref": "#/definitions/Vector3" },
            "crs": { "type": "string", "description": "坐标参考系EPSG代码" }
          }
        },
        "activeLayers": {
          "type": "array",
          "description": "已激活的环境图层",
          "items": {
            "type": "object",
            "properties": {
              "layerId": { "type": "string" },
              "layerName": { "type": "string" },
              "visible": { "type": "boolean" },
              "opacity": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        },
        "spatialAnchors": {
          "type": "array",
          "description": "用户提及的空间锚点",
          "items": {
            "type": "object",
            "properties": {
              "anchorId": { "type": "string" },
              "label": { "type": "string", "description": "用户描述(如'主入口')" },
              "location": { "$ref": "#/definitions/Vector3" },
              "createdAt": { "type": "string" }
            }
          }
        },
        "loadedEntities": {
          "type": "array",
          "description": "已加载的实体清单",
          "items": { "$ref": "#/definitions/EntityRef" }
        },
        "bimModels": {
          "type": "array",
          "description": "已加载的BIM模型列表",
          "items": {
            "type": "object",
            "properties": {
              "modelId": { "type": "string", "description": "模型唯一标识" },
              "modelName": { "type": "string", "description": "模型名称" },
              "visible": { "type": "boolean", "description": "是否可见", "default": true },
              "loadedNodes": { "type": "number", "description": "已加载的构件数量" },
              "totalNodes": { "type": "number", "description": "总构件数量" },
              "nodeTree": { "type": "object", "description": "构件树结构（通过 GetNodeTree 获取）" },
              "transform": {
                "type": "object",
                "description": "模型变换参数",
                "properties": {
                  "location": { "$ref": "#/definitions/Vector3" },
                  "rotation": { "$ref": "#/definitions/Rotator" },
                  "scale": { "$ref": "#/definitions/Vector3" }
                }
              }
            },
            "required": ["modelId", "modelName"]
          }
        },
        "bimState": {
          "type": "object",
          "description": "BIM模型操作状态（高亮/隔离/隐藏等）",
          "properties": {
            "isolatedNodes": {
              "type": "array",
              "description": "被隔离显示的构件ID列表（其他构件隐藏）",
              "items": { "type": "string" }
            },
            "hiddenNodes": {
              "type": "array",
              "description": "被隐藏的构件ID列表",
              "items": { "type": "string" }
            },
            "highlightedNodes": {
              "type": "array",
              "description": "高亮的构件ID列表",
              "items": { "type": "string" }
            },
            "colorOverrides": {
              "type": "object",
              "description": "构件颜色覆盖设置",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "nodeIds": { "type": "array", "items": "string" },
                  "color": { "type": "string", "description": "颜色值（如 #FF0000）" },
                  "transparency": { "type": "number", "minimum": 0, "maximum": 1 }
                }
              }
            },
            "sectionPlane": {
              "type": "object",
              "description": "剖切平面状态",
              "properties": {
                "active": { "type": "boolean", "description": "剖切是否激活" },
                "plane": {
                  "type": "object",
                  "description": "剖切平面参数",
                  "properties": {
                    "normal": { "$ref": "#/definitions/Vector3", "description": "平面法向量" },
                    "distance": { "type": "number", "description": "平面到原点距离" }
                  }
                },
                "targetNodes": { "type": "array", "items": "string", "description": "受剖切影响的构件ID列表" }
              }
            }
          }
        },
        "gisLayers": {
          "type": "array",
          "description": "已加载的GIS图层列表",
          "items": {
            "type": "object",
            "properties": {
              "layerId": { "type": "string", "description": "图层唯一标识" },
              "layerName": { "type": "string", "description": "图层名称" },
              "layerType": {
                "type": "string",
                "description": "图层类型",
                "enum": ["GeoLayer", "WMS", "WMTS", "3DTiles", "Vector", "Image"]
              },
              "visible": { "type": "boolean", "description": "是否可见", "default": true },
              "opacity": { "type": "number", "description": "透明度", "minimum": 0, "maximum": 1, "default": 1 },
              "url": { "type": "string", "description": "图层服务URL" },
              "crs": { "type": "string", "description": "坐标参考系" }
            },
            "required": ["layerId", "layerName", "layerType"]
          }
        },
        "gisState": {
          "type": "object",
          "description": "GIS图层操作状态",
          "properties": {
            "selectedFeatures": {
              "type": "array",
              "description": "选中的GIS要素ID列表",
              "items": { "type": "string" }
            },
            "highlightedFeatures": {
              "type": "array",
              "description": "高亮的GIS要素ID列表",
              "items": { "type": "string" }
            },
            "visibleExtent": {
              "type": "object",
              "description": "当前可见范围（地图视图范围）",
              "properties": {
                "minX": { "type": "number" },
                "minY": { "type": "number" },
                "maxX": { "type": "number" },
                "maxY": { "type": "number" }
              }
            }
          }
        },
        "cameraObjects": {
          "type": "array",
          "description": "相机机位预设对象列表（通过 App.Camera 创建）",
          "items": {
            "type": "object",
            "properties": {
              "cameraId": { "type": "string", "description": "机位唯一标识" },
              "entityName": { "type": "string", "description": "机位名称（如'主入口视角'）" },
              "location": { "$ref": "#/definitions/Vector3", "description": "机位位置" },
              "rotation": { "$ref": "#/definitions/Rotator", "description": "机位旋转角度" },
              "locationLimit": {
                "type": "array",
                "description": "位置限制区域",
                "items": { "$ref": "#/definitions/Vector3" }
              },
              "pitchLimit": { "type": "array", "items": "number" },
              "yawLimit": { "type": "array", "items": "number" },
              "viewDistanceLimit": { "type": "array", "items": "number" },
              "fieldOfView": { "type": "number", "default": 90 },
              "controlMode": { "type": "string", "enum": ["RTS", "TPS", "FPS"], "default": "RTS" }
            },
            "required": ["cameraId", "entityName", "location", "rotation"]
          }
        },
        "environment": {
          "type": "object",
          "description": "场景环境设置",
          "properties": {
            "weather": {
              "type": "string",
              "enum": ["sunny", "rainy", "snowy", "foggy", "cloudy"],
              "description": "天气状态",
              "default": "sunny"
            },
            "timeOfDay": {
              "type": "number",
              "description": "时间（小时，0-24）",
              "minimum": 0,
              "maximum": 24,
              "default": 12
            },
            "shadowsEnabled": {
              "type": "boolean",
              "description": "是否启用阴影",
              "default": true
            }
          }
        },
        "aesTiles": {
          "type": "object",
          "description": "AES Tiles底板状态",
          "properties": {
            "tileId": { "type": "string", "description": "底板ID" },
            "activeNodes": {
              "type": "array",
              "description": "激活的节点ID列表",
              "items": { "type": "string" }
            },
            "highlightedNodes": {
              "type": "array",
              "description": "高亮的节点ID列表",
              "items": { "type": "string" }
            }
          }
        },
        "clusterDeployment": {
          "type": "object",
          "description": "点聚合部署状态（私有化/lite环境）",
          "properties": {
            "clusterId": { "type": "string", "description": "聚合ID" },
            "dataSource": { "type": "string", "description": "数据源URL或标识" },
            "styleConfig": { "type": "object", "description": "样式配置" },
            "visible": { "type": "boolean", "default": true }
          }
        },
        "spatialUnderstanding": {
          "type": "object",
          "description": "空间理解状态（坐标系统）",
          "properties": {
            "globalOrigin": { "$ref": "#/definitions/Vector3", "description": "全局原点" },
            "coordinateSystems": {
              "type": "object",
              "description": "坐标系统定义",
              "properties": {
                "gis": {
                  "type": "object",
                  "properties": {
                    "crs": { "type": "string", "description": "GIS坐标系（如EPSG:4326）" }
                  }
                },
                "cartesian": {
                  "type": "object",
                  "properties": {
                    "origin": { "$ref": "#/definitions/Vector3" }
                  }
                },
                "screen": {
                  "type": "object",
                  "properties": {
                    "width": { "type": "number" },
                    "height": { "type": "number" }
                  }
                }
              }
            }
          }
        }
      }
    },

    "task": {
      "type": "object",
      "description": "【任务进度树/Cold Memory】宏观目标追踪",
      "properties": {
        "goal": {
          "type": "string",
          "description": "最终目标描述"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "in_progress", "completed", "failed"],
          "default": "pending"
        },
        "completedSteps": {
          "type": "array",
          "description": "已完成步骤",
          "items": {
            "type": "object",
            "properties": {
              "stepId": { "type": "string" },
              "description": { "type": "string" },
              "completedAt": { "type": "string" },
              "result": { "type": "string", "enum": ["success", "partial", "skipped"] }
            }
          }
        },
        "pendingSteps": {
          "type": "array",
          "description": "待执行步骤",
          "items": {
            "type": "object",
            "properties": {
              "stepId": { "type": "string" },
              "description": { "type": "string" },
              "dependencies": { 
                "type": "array", 
                "items": { "type": "string" },
                "description": "依赖的前置步骤ID"
              },
              "blocking": { "type": "boolean", "description": "是否为阻塞性步骤" }
            }
          }
        },
        "slots": {
          "type": "object",
          "description": "待确认的参数槽位",
          "properties": {
            "required": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "slotId": { "type": "string" },
                  "description": { "type": "string" },
                  "expectedType": { "type": "string" },
                  "status": { "type": "string", "enum": ["empty", "filled", "confirmed"] },
                  "value": {}
                }
              }
            },
            "optional": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "slotId": { "type": "string" },
                  "description": { "type": "string" },
                  "status": { "type": "string", "enum": ["empty", "filled", "confirmed"] },
                  "value": {}
                }
              }
            }
          }
        },
        "validationRules": {
          "type": "array",
          "description": "任务校验规则",
          "items": {
            "type": "object",
            "properties": {
              "ruleId": { "type": "string" },
              "description": { "type": "string" },
              "check": { "type": "string", "description": "校验逻辑描述" },
              "critical": { "type": "boolean", "description": "是否为关键规则" }
            }
          }
        }
      }
    },
    "renderer": {
      "type": "object",
      "description": "渲染器状态（来自 wdp-api-initialization-unified）",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["initializing", "ready", "error", "disconnected"],
          "description": "渲染器状态",
          "default": "initializing"
        },
        "startTime": {
          "type": "string",
          "format": "date-time",
          "description": "渲染启动时间"
        },
        "resolution": {
          "type": "array",
          "description": "渲染分辨率 [width, height]",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "number" }
        },
        "networkStats": {
          "type": "object",
          "description": "网络传输质量统计",
          "properties": {
            "latency": { "type": "number", "description": "往返延迟(ms)" },
            "frameRate": { "type": "number", "description": "平均帧率(fps)" },
            "bandwidth": { "type": "number", "description": "带宽大小(Mbps)" },
            "packetLoss": { "type": "number", "description": "丢包率(%)" }
          }
        }
      }
    }
  },

  "required": ["_meta", "transient", "spatial", "task", "renderer"]
}
